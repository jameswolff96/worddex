# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in your Supabase project: Settings → API

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable (anon) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Service role key — server-side only, never exposed to the browser.
# Required for account deletion (admin auth operations).
# Found in: Supabase → Settings → API → Service role key
# Keep this secret — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── hCaptcha ──────────────────────────────────────────────────────────────────
# Required for anonymous (guest) sign-ins.
# Create a free account at https://www.hcaptcha.com, add a site, and copy the site key.
# You must also enable hCaptcha in Supabase: Authentication → Bot and Abuse Protection.

NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key-here

# ── GitHub Actions secrets (not used by Next.js directly) ────────────────────
# The scheduled-cleanup workflow calls the Edge Function via HTTP.
# Add these as repository secrets in GitHub: Settings → Secrets → Actions.
#
#   SUPABASE_URL       = same value as NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_ANON_KEY  = your Supabase anon key (Settings → API → Anon key)
#                        Note: this is different from the publishable key above.
